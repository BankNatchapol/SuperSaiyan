{
  "name": "supersaiyan-control-center",
  "version": "0.1.0",
  "private": true,
  "description": "Optional desktop control center for the SuperSaiyan Claude Code pipeline",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start -w @supersaiyan/desktop",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w @supersaiyan/desktop",
    "test:e2e:packaged": "npm run test:e2e:packaged -w @supersaiyan/desktop",
    "test:e2e:live": "npm run test:e2e:live -w @supersaiyan/desktop",
    "test:control-center": "npm test && npm run lint && npm run test:e2e && npm run test:e2e:packaged",
    "lint": "npm run typecheck --workspaces --if-present",
    "package:mac": "npm run package -w @supersaiyan/desktop",
    "package:mac:arm64": "npm run package -w @supersaiyan/desktop -- --arch=arm64",
    "package:mac:x64": "npm run package -w @supersaiyan/desktop -- --arch=x64"
  },
  "engines": {
    "node": ">=22"
  }
}
