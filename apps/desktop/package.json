{
  "name": "@supersaiyan/desktop",
  "productName": "SuperSaiyan Control Center",
  "version": "0.1.0",
  "private": true,
  "main": ".vite/build/main.js",
  "scripts": {
    "postinstall": "node scripts/ensure-node-pty-helper.mjs",
    "prestart": "node scripts/ensure-node-pty-helper.mjs",
    "start": "electron-forge start",
    "build": "vite build --config vite.renderer.config.ts && tsc --noEmit",
    "prepackage": "node scripts/ensure-node-pty-helper.mjs",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@supersaiyan/control-core": "0.1.0",
    "@supersaiyan/control-protocol": "0.1.0",
    "@supersaiyan/ui": "0.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^24.10.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.4.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
